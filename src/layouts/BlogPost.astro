---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] | {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: string;
};

const raw = Astro.props;
const props = 'frontmatter' in raw ? (raw as any).frontmatter : raw;
const { title, description, pubDate, updatedDate, heroImage } = props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			article {
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.5em;
			}
.article-header {
				padding: 4em 0 2em;
			}
			.article-date {
				font-size: 0.8em;
				color: var(--text-secondary);
				letter-spacing: 0.05em;
				text-transform: uppercase;
				margin-bottom: 1em;
			}
			.article-date .last-updated-on {
				font-style: italic;
				text-transform: none;
				letter-spacing: normal;
			}
			.article-header h1 {
				font-family: var(--font-serif);
				font-weight: 600;
				font-size: 2.5em;
				line-height: 1.15;
				margin: 0 0 0.4em 0;
				color: var(--text-primary);
			}
			.article-description {
				font-family: var(--font-serif);
				font-weight: 400;
				font-style: italic;
				font-size: 1.15em;
				line-height: 1.5;
				color: var(--text-secondary);
				margin: 0;
			}
			.article-divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 2em 0 3em;
			}
			.prose {
				font-size: 18px;
				line-height: 1.7;
				color: var(--text-primary);
			}
			@media (max-width: 720px) {
				.article-header {
					padding: 2.5em 0 1.5em;
				}
				.article-header h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="article-header">
					{pubDate && (
						<div class="article-date">
							<FormattedDate date={pubDate instanceof Date ? pubDate : new Date(pubDate)} />
							{updatedDate && (
								<span class="last-updated-on">
									&mdash; Updated <FormattedDate date={updatedDate instanceof Date ? updatedDate : new Date(updatedDate)} />
								</span>
							)}
						</div>
					)}
					<h1>{title}</h1>
					{description && <p class="article-description">{description}</p>}
				</div>
				<hr class="article-divider" />
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
