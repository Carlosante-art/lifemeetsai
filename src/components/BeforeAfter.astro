---
interface Props {
	beforeImage: string;
	afterImage: string;
	beforeLabel?: string;
	afterLabel?: string;
}

const { beforeImage, afterImage, beforeLabel = "Before", afterLabel = "After" } = Astro.props;
---

<div class="before-after">
	<figure>
		<div class="image-wrap">
			<img src={beforeImage} alt={beforeLabel} />
		</div>
		<figcaption>{beforeLabel}</figcaption>
	</figure>
	<figure>
		<div class="image-wrap">
			<img src={afterImage} alt={afterLabel} />
		</div>
		<figcaption>{afterLabel}</figcaption>
	</figure>
</div>
<style>
	.before-after {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5em;
		max-width: 800px;
		margin: 2.5em auto;
	}
	figure {
		margin: 0;
	}
	.image-wrap {
		border: 1px solid var(--border);
		border-radius: 4px;
		overflow: hidden;
	}
	.image-wrap img {
		display: block;
		width: 100%;
		border-radius: 0;
	}
	figcaption {
		margin-top: 0.5em;
		text-align: center;
		font-size: 0.85em;
		color: var(--text-secondary);
		letter-spacing: 0.02em;
	}
	@media (max-width: 720px) {
		.before-after {
			grid-template-columns: 1fr;
		}
	}
</style>
