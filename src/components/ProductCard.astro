---
interface Props {
	name: string;
	description: string;
	price: string;
	imageUrl: string;
	affiliateUrl: string;
}

const { name, description, price, imageUrl, affiliateUrl } = Astro.props;
---

<div class="product-card">
	<img src={imageUrl} alt={name} class="product-image" />
	<div class="product-info">
		<h3>{name}</h3>
		<p class="product-desc">{description}</p>
		<p class="product-price">{price}</p>
		<a href={affiliateUrl} rel="sponsored nofollow" target="_blank">
			View on Amazon
		</a>
	</div>
</div>
<style>
	.product-card {
		max-width: 360px;
		margin: 2.5em auto;
		border: 1px solid var(--border);
		border-radius: 4px;
		overflow: hidden;
		background: white;
	}
	.product-image {
		width: 100%;
		height: 200px;
		object-fit: cover;
		display: block;
		border-radius: 0;
	}
	.product-info {
		padding: 1.5em;
	}
	.product-info h3 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 1.1em;
		margin-bottom: 0.3em;
	}
	.product-desc {
		font-size: 0.9em;
		color: var(--text-secondary);
		margin-bottom: 0.75em;
	}
	.product-price {
		font-size: 1.2em;
		font-weight: 600;
		margin-bottom: 1em;
	}
	.product-info a {
		display: inline-block;
		background: var(--accent);
		color: white;
		padding: 0.6em 1.5em;
		border-radius: 4px;
		text-decoration: none;
		font-size: 0.9em;
		font-weight: 500;
		transition: background 0.2s ease;
	}
	.product-info a:hover {
		background: var(--accent-hover);
		color: white;
	}
</style>
