---
interface Props {
	screenshot: string;
	caption: string;
	alt?: string;
}

const { screenshot, caption, alt } = Astro.props;
---

<figure class="conversation">
	<div class="conversation-image">
		<img src={screenshot} alt={alt || caption} />
	</div>
	<figcaption>{caption}</figcaption>
</figure>
<style>
	.conversation {
		max-width: 800px;
		margin: 2.5em auto;
		padding: 0;
	}
	.conversation-image {
		border: 1px solid var(--border);
		border-radius: 4px;
		overflow: hidden;
	}
	.conversation-image img {
		display: block;
		width: 100%;
		border-radius: 0;
	}
	figcaption {
		margin-top: 0.75em;
		font-size: 0.85em;
		font-style: italic;
		color: var(--text-secondary);
		line-height: 1.5;
		letter-spacing: 0.02em;
	}
</style>
