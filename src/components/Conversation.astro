---
interface Props {
	screenshot: string;
	caption: string;
}

const { screenshot, caption } = Astro.props;
---

<figure class="mx-auto my-8 max-w-[600px]">
	<div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm">
		<img src={screenshot} alt={caption} class="block w-full" />
	</div>
	<figcaption class="mt-3 text-center text-sm italic text-gray-500">
		{caption}
	</figcaption>
</figure>
