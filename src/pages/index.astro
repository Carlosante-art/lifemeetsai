---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
	.filter((post) => !post.id.startsWith('test-'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const latestPostUrl = allPosts.length > 0 ? `/blog/${allPosts[0].id}/` : '/blog';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero image */
			.hero-banner {
				width: 100%;
				max-height: 420px;
				overflow: hidden;
			}
			.hero-banner img {
				width: 100%;
				height: 420px;
				object-fit: cover;
				object-position: center 40%;
				display: block;
			}

			/* Hero */
			.hero {
				max-width: 680px;
				margin: 0 auto;
				padding: 3em 1.5em 4em;
			}
			.hero h1 {
				font-family: var(--font-serif);
				font-weight: 600;
				font-size: 3em;
				line-height: 1.1;
				margin-bottom: 0.5em;
				color: var(--text-primary);
			}
			.hero p {
				font-size: 1.15em;
				line-height: 1.7;
				color: var(--text-secondary);
				max-width: 560px;
				margin-bottom: 2em;
			}
			.hero-links {
				display: flex;
				gap: 2em;
				align-items: center;
			}
			.hero-links a.primary {
				background: var(--accent);
				color: white;
				padding: 0.75em 1.75em;
				border-radius: 4px;
				text-decoration: none;
				font-weight: 500;
				transition: background 0.2s ease;
			}
			.hero-links a.primary:hover {
				background: var(--accent-hover);
				color: white;
			}
			.hero-links a.secondary {
				color: var(--text-secondary);
				text-decoration: none;
				font-size: 0.95em;
				transition: color 0.2s ease;
			}
			.hero-links a.secondary:hover {
				color: var(--text-primary);
			}

			/* Stories */
			.stories {
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.5em 4em;
			}
			.stories h2 {
				font-family: var(--font-serif);
				font-weight: 500;
				font-size: 1.5em;
				margin-bottom: 2em;
				padding-bottom: 0.75em;
				border-bottom: 1px solid var(--border);
			}
			.story-item {
				display: block;
				text-decoration: none;
				padding: 1.75em 0;
				border-bottom: 1px solid var(--border);
				transition: opacity 0.2s ease;
			}
			.story-item:first-of-type {
				padding-top: 0;
			}
			.story-item:hover {
				opacity: 0.7;
			}
			.story-image {
				width: 100%;
				aspect-ratio: 2 / 1;
				object-fit: cover;
				border-radius: 4px;
				margin-bottom: 1em;
			}
			.story-date {
				font-size: 0.8em;
				color: var(--text-secondary);
				letter-spacing: 0.02em;
				margin-bottom: 0.5em;
			}
			.story-title {
				font-family: var(--font-serif);
				font-weight: 500;
				font-size: 1.35em;
				line-height: 1.3;
				color: var(--text-primary);
				margin-bottom: 0.4em;
			}
			.story-excerpt {
				font-size: 0.95em;
				line-height: 1.6;
				color: var(--text-secondary);
				margin: 0;
			}
			.empty-state {
				color: var(--text-secondary);
				font-size: 1em;
				line-height: 1.7;
			}
			.empty-state a {
				color: var(--accent);
			}

			/* How it works */
			.how-it-works {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em;
			}
			.how-it-works h2 {
				font-family: var(--font-serif);
				font-weight: 500;
				font-size: 1.5em;
				margin-bottom: 2.5em;
			}
			.how-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 3em;
			}
			.how-grid h3 {
				font-family: var(--font-serif);
				font-weight: 500;
				font-size: 1.1em;
				margin-bottom: 0.5em;
				color: var(--text-primary);
			}
			.how-grid p {
				font-size: 0.9em;
				line-height: 1.6;
				color: var(--text-secondary);
				margin: 0;
			}

			/* About teaser */
			.about-teaser {
				max-width: 680px;
				margin: 0 auto;
				padding: 4em 1.5em 5em;
				border-top: 1px solid var(--border);
			}
			.about-teaser p {
				font-size: 1.05em;
				line-height: 1.7;
				color: var(--text-secondary);
				max-width: 560px;
			}
			.about-teaser a {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95em;
			}
			.about-teaser a:hover {
				color: var(--accent-hover);
			}

			/* Email capture */
			.home-email {
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.5em;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 3em 1.5em 2.5em;
				}
				.hero-banner {
					padding: 0 1em;
				}
				.hero-banner img {
					height: 240px;
					border-radius: 8px;
				}
				.hero h1 {
					font-size: 2.2em;
				}
				.hero-links {
					flex-direction: column;
					align-items: flex-start;
					gap: 1em;
				}
				.how-grid {
					grid-template-columns: 1fr;
					gap: 2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- HERO IMAGE -->
			<div class="hero-banner">
				<img src="/images/hero-home.webp" alt="Warm sunlit living room corner with leather chair, eucalyptus, and natural light" />
			</div>

			<!-- HERO -->
			<section class="hero">
				<h1>Real AI conversations.<br />Real life decisions.</h1>
				<p>
					I document how I use AI to solve everyday situations — from organizing
					a pantry to choosing non-toxic cookware — with full screenshots, real context, and honest
					results. For people who keep hearing about AI but feel like it's not for them.
				</p>
				<div class="hero-links">
					<a href={latestPostUrl} class="primary">Read the latest story</a>
					<a href="/about" class="secondary">What is this? &rarr;</a>
				</div>
			</section>

			<!-- LATEST STORIES -->
			<section class="stories">
				<h2>Latest Stories</h2>
				{allPosts.length > 0 ? (
					allPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="story-item">
							{post.data.heroImage && (
								<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : ''} alt="" class="story-image" />
							)}
							<p class="story-date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="story-title">{post.data.title}</p>
							<p class="story-excerpt">{post.data.description}</p>
						</a>
					))
				) : (
					<p class="empty-state">
						The first story drops this weekend. Check back soon — or reach out at{' '}
						<a href="mailto:contact@lifemeetsai.com">contact@lifemeetsai.com</a> to be notified.
					</p>
				)}
			</section>

			<!-- HOW IT WORKS -->
			<section class="how-it-works">
				<h2>How this site works</h2>
				<div class="how-grid">
					<div>
						<h3>Real situations.</h3>
						<p>
							Not hypothetical use cases. Actual decisions from my life (or friends and family) —
							cookware, apartments, home fragrance, organization.
						</p>
					</div>
					<div>
						<h3>Full conversations.</h3>
						<p>
							Every post includes screenshots of the actual AI conversation.
							You see the prompts, the mistakes, and what came back.
						</p>
					</div>
					<div>
						<h3>Honest results.</h3>
						<p>
							I show what worked, what didn't, and what I'd do differently.
							No hype. No shilling. Just honest reporting.
						</p>
					</div>
				</div>
			</section>

			<!-- EMAIL CAPTURE -->
			<section class="home-email">
				<EmailCapture
					heading="Get the prompt library"
					description="I'm building a library of the exact ChatGPT prompts I use for real decisions. Email only when there's something worth sending."
					buttonText="Send me the prompts"
				/>
			</section>

			<!-- ABOUT TEASER -->
			<section class="about-teaser">
				<p>
					I'm Carl — an ordinary person who started using ChatGPT for real decisions and noticed
					something: the answers were better than anything I found on Google, Pinterest, or
					the "10 best X" articles clogging up every search. So I started documenting the conversations.
				</p>
				<a href="/about">Read more &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
