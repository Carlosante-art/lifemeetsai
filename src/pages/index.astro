---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
	.filter((post) => !post.id.startsWith('test-'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const latestPostUrl = allPosts.length > 0 ? `/blog/${allPosts[0].id}/` : '/blog';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- HERO -->
			<section class="mx-auto max-w-4xl px-6 py-24 text-center">
				<h1 class="mb-8 text-5xl font-bold leading-[1.1] tracking-tight text-gray-900 md:text-6xl">
					Real AI conversations.<br />Real life decisions.
				</h1>
				<p class="mx-auto mb-12 max-w-2xl text-xl leading-relaxed text-gray-500">
					I'm Carlosante. I document how I use AI to solve everyday situations — from choosing
					paint colors to organizing a closet — with full screenshots, real context, and honest
					results. For people who keep hearing about AI but feel like it's not for them.
				</p>
				<div class="flex flex-col items-center justify-center gap-5 sm:flex-row">
					<a
						href={latestPostUrl}
						class="inline-block rounded-lg bg-blue-600 px-8 py-3.5 text-lg font-medium text-white no-underline transition-colors hover:bg-blue-700"
					>
						Read the latest story
					</a>
					<a
						href="/about"
						class="inline-block text-lg font-medium text-gray-500 no-underline transition-colors hover:text-gray-900"
					>
						What is this? &rarr;
					</a>
				</div>
			</section>

			<!-- LATEST STORIES -->
			<section class="mx-auto max-w-5xl px-6 py-20">
				<h2 class="mb-12 text-center text-3xl font-bold tracking-tight text-gray-900">Latest Stories</h2>
				{allPosts.length > 0 ? (
					<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
						{allPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="group block rounded-xl border border-gray-200 p-6 no-underline transition-shadow hover:shadow-lg">
								<p class="mb-3 text-sm text-gray-400">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3 class="mb-2 text-lg font-semibold leading-snug break-words hyphens-none text-gray-900 transition-colors group-hover:text-blue-600">
									{post.data.title}
								</h3>
								<p class="text-base leading-relaxed text-gray-500">
									{post.data.description}
								</p>
							</a>
						))}
					</div>
				) : (
					<p class="mx-auto max-w-lg text-center text-lg leading-relaxed text-gray-400">
						The first story drops this weekend. Check back soon — or reach out at{' '}
						<a href="mailto:contact@lifemeetsai.com" class="text-blue-600 hover:text-blue-800">contact@lifemeetsai.com</a> to be notified.
					</p>
				)}
			</section>

			<!-- HOW IT WORKS -->
			<section class="mx-auto max-w-5xl px-6 py-20">
				<h2 class="mb-12 text-center text-3xl font-bold tracking-tight text-gray-900">How this site works</h2>
				<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
					<div class="rounded-xl border border-gray-100 bg-gray-50 p-8">
						<h3 class="mb-3 text-xl font-bold text-gray-900">Real situations.</h3>
						<p class="text-base leading-relaxed text-gray-500">
							Not hypothetical use cases. Actual decisions from my life (or readers') —
							paint colors, furniture, gadgets, organization.
						</p>
					</div>
					<div class="rounded-xl border border-gray-100 bg-gray-50 p-8">
						<h3 class="mb-3 text-xl font-bold text-gray-900">Full conversations.</h3>
						<p class="text-base leading-relaxed text-gray-500">
							Every post includes screenshots of the actual AI conversation.
							You see the prompts, the mistakes, and what came back.
						</p>
					</div>
					<div class="rounded-xl border border-gray-100 bg-gray-50 p-8">
						<h3 class="mb-3 text-xl font-bold text-gray-900">Honest results.</h3>
						<p class="text-base leading-relaxed text-gray-500">
							I show what worked, what didn't, and what I'd do differently.
							No hype. No shilling. Just honest reporting.
						</p>
					</div>
				</div>
			</section>

			<!-- ABOUT TEASER -->
			<section class="mx-auto max-w-3xl px-6 py-20 text-center">
				<h2 class="mb-6 text-3xl font-bold tracking-tight text-gray-900">About Carlosante</h2>
				<p class="mx-auto mb-8 max-w-2xl text-xl leading-relaxed text-gray-500">
					I'm 27, based in Sweden, and just a regular person who stumbled into realizing
					how useful AI can be when you stop treating it like a chatbot and start treating
					it like a smart friend who's seen everything.
				</p>
				<a
					href="/about"
					class="inline-block text-lg font-medium text-blue-600 no-underline transition-colors hover:text-blue-800"
				>
					Read more &rarr;
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
